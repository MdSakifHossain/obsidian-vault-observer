# =============================================================================
# config.env — Vault Observer Configuration
# Edit ONLY this file to change any setting.
# After editing, run ./install.sh to apply changes.
# =============================================================================

# Full path to your Obsidian vault
VAULT_DIR="$HOME/obsidian-vault"

# How often the observer wakes up and checks for changes (in seconds)
# 180 = 3 minutes. This is also your maximum possible data loss window.
INTERVAL_SECONDS=180

# Git branch to push to
GIT_BRANCH="main"

# Git remote name (almost always "origin")
GIT_REMOTE="origin"

# Commit author details (shows up in git log)
COMMIT_AUTHOR_NAME="Vault Observer"
COMMIT_AUTHOR_EMAIL="observer@local"

# Log file location
LOG_FILE="$HOME/.local/logs/vault-observer.log"

# Maximum lines to keep in the log before rotating
MAX_LOG_LINES=500
